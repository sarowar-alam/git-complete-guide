   checkout develop
   merge release/v1.0 id: "sync develop"

   checkout main
   branch hotfix/crash
   checkout hotfix/crash
   commit id: "fix crash"
   checkout main
   merge hotfix/crash id: "hotfix merged" tag: "v1.0.1"
